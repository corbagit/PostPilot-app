# PostPilot Production Environment
# Copy this to .env.production and fill in your production secrets

# Server
NODE_ENV=production
PORT=3000

# Database (SQLite path inside container)
DATABASE_PATH=/app/data/postpilot.db

# JWT — GENERATE A RANDOM SECRET: openssl rand -hex 64
JWT_SECRET=replace-this-with-a-random-64-char-hex-string
JWT_EXPIRES_IN=7d

# Stripe — Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxxxxxxxxxx
# Stripe webhook secret — Get from Stripe Dashboard > Webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe Price IDs — Create products/prices in Stripe Dashboard
STRIPE_PRICE_STARTER=price_starter_monthly
STRIPE_PRICE_PRO=price_pro_monthly