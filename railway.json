{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "cd web && npm install 2>&1 && npm run build 2>&1 && cd ../api && npm install 2>&1"
  },
  "deploy": {
    "startCommand": "node api/src/index.js",
    "healthcheckPath": "/api/health",
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}