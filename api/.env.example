# ── PostPilot API — Environment Configuration ───────────
# Copy this file to .env and fill in your values.
# For production, create .env.production and use ./deploy.sh

# Server
PORT=3000
NODE_ENV=development

# Database (SQLite)
DATABASE_PATH=./data/postpilot.db

# ── JWT Authentication ──────────────────────────────
# Generate a strong secret: openssl rand -hex 64
JWT_SECRET=change-me-to-a-random-secret-in-production
JWT_EXPIRES_IN=7d

# ── Stripe Billing ──────────────────────────────────
# Get test keys at: https://dashboard.stripe.com/apikeys
# Get live keys at: https://dashboard.stripe.com/apikeys (after going live)

# Secret Key (starts with sk_test_ or sk_live_)
# Leave as placeholder for mock mode (great for development without Stripe)
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# Publishable Key (starts with pk_test_ or pk_live_)
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Webhook Signing Secret (from Stripe CLI: stripe listen --forward-to ...)
# Or from Stripe Dashboard: Developers → Webhooks → your endpoint → Signing secret
# Leave as placeholder to skip webhook verification in development
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Stripe Price IDs ────────────────────────────────
# Run "node scripts/setup-stripe.js" to create products/prices automatically
# Or create them manually in Stripe Dashboard → Products
# Price IDs look like: price_1QwxYZ2eZvKYlo2C...

# Starter Plan: $29/month, 10 posts, 1 platform
# STRIPE_PRICE_STARTER=price_starter_monthly

# Pro Plan: $59/month, 30 posts, 3 platforms, image gen
# STRIPE_PRICE_PRO=price_pro_monthly

# Optional — Annual pricing (2 months free)
# STRIPE_PRICE_STARTER_ANNUAL=price_starter_annual
# STRIPE_PRICE_PRO_ANNUAL=price_pro_annual

# ── PayPal Billing ──────────────────────────────────
# Get credentials at: https://developer.paypal.com/dashboard/applications
# Sandbox (testing) keys start with A...
# Live keys start with A... (from "Live" app in PayPal Dashboard)

# Client ID from PayPal App
# Leave as placeholder for mock mode
PAYPAL_CLIENT_ID=placeholder_paypal_client_id

# Client Secret from PayPal App
PAYPAL_CLIENT_SECRET=placeholder_paypal_client_secret

# Mode: "sandbox" for testing, "live" for production
PAYPAL_MODE=sandbox

# Webhook ID (for signature verification)
# Found at: PayPal Developer Dashboard → your app → Webhooks
# Optional — verification skipped if not set
# PAYPAL_WEBHOOK_ID=your_webhook_id